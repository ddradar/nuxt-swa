{
  "name": "nuxt-swa-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Nuxt module for Azure Static Web Apps",
  "repository": "ddradar/nuxt-swa",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.x"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^10.13.1"
    }
  },
  "scripts": {
    "prepare": "husky",
    "dev": "swa start",
    "build": "pnpm -C packages/nuxt-swa build && pnpm -C docs build",
    "changelog": "changelogen --bump",
    "format": "pnpm run \"/^format:.*/\"",
    "format:eslint": "eslint . --fix",
    "format:prettier": "pnpm lint:prettier --write",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier -l \"**/*.{json,yml,js,mjs,ts,vue}\"",
    "preview": "swa start docs/.output/public --api-location docs/.output/server",
    "test": "pnpm -r test"
  },
  "lint-staged": {
    "*.{js,mjs,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml}": "prettier --write"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.8",
    "@vitest/eslint-plugin": "^1.6.14",
    "changelogen": "^0.6.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "resolutions": {
    "@nuxt/test-utils>h3-next": "npm:h3@^2.0.1-rc.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "vue-demi"
    ]
  }
}
