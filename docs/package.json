{
  "name": "nuxt-swa-docs",
  "private": true,
  "version": "1.0.1",
  "description": "Nuxt SWA module documentation and playground",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prepare": "pnpm -C ../packages/nuxt-swa prepare:docs && nuxi prepare",
    "dev": "nuxi dev",
    "build": "nuxi build && node -e \"fs.renameSync('./staticwebapp.config.json', './.output/public/staticwebapp.config.json')\"",
    "test:types": "nuxi typecheck"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.103",
    "@iconify-json/simple-icons": "^1.2.79",
    "@iconify-json/vscode-icons": "^1.2.46",
    "@nuxt/content": "3.11.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.6.0",
    "@takumi-rs/core": "^0.73.1",
    "better-sqlite3": "^12.9.0",
    "nuxt": "^4.1.0",
    "nuxt-llms": "0.2.0",
    "nuxt-og-image": "^6.3.7",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "nuxt-applicationinsights": "^1.0.1",
    "nuxt-swa": "workspace:*",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.7"
  }
}
