{
  "name": "nuxt-swa-docs",
  "private": true,
  "version": "1.0.1",
  "description": "Nuxt SWA module documentation and playground",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prepare": "pnpm -C ../packages/nuxt-swa prepare:docs && nuxi prepare",
    "dev": "nuxi dev",
    "build": "nuxi build && node -e \"fs.renameSync('./staticwebapp.config.json', './.output/public/staticwebapp.config.json')\"",
    "test:types": "nuxi typecheck"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.112",
    "@iconify-json/simple-icons": "^1.2.86",
    "@iconify-json/vscode-icons": "^1.2.57",
    "@nuxt/content": "3.14.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.8.2",
    "@takumi-rs/core": "^1.8.5",
    "better-sqlite3": "^12.10.1",
    "nuxt": "^4.4.8",
    "nuxt-llms": "0.2.0",
    "nuxt-og-image": "^6.5.3",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "nuxt-applicationinsights": "^1.0.1",
    "nuxt-swa": "workspace:*",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5"
  }
}
